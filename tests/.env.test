# App
PROTOCOL=http
HOST=localhost
PORT=5050
NODE_ENV=development
# NODE_ENV=production
# NODE_ENV=test
# TEST_MODE=true

# Cors
CORS_ORIGIN=http://localhost:3000

# Secrets
JWT_SECRET=example-secret
JWT_REFRESH_TOKEN_EXPIRATION=15d
JWT_ACCESS_TOKEN_EXPIRATION=1d

# Database
# @AhmedElsenaty
# TODO: Change default credientials in production
# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tsts_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Minio
MINIO_PROTOCOL=http
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_REGION=us-east-1
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_BUCKET=tsts
MINIO_CERT_FILE=/root/certs/staging.myapp.local.pem
MINIO_KEY_FILE=/root/certs/staging.myapp.local-key.pem
MINIO_CA_CERT=/root/certs/ca.crt

# Mail
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=fc0685c4bd0437
MAIL_PASS=24f66168af2f5b

# Trusted Device Auth
RP_ID=192.168.56.1
RP_ORIGINS=http://192.168.56.1,http://192.168.56.1:3000

NODE_EXTRA_CA_CERTS= /certs/rootCA.pem

