# Test environment — used by Jest integration tests
# Do NOT commit real secrets here
NODE_ENV=test
JWT_SECRET=test-secret-key-for-jest-only-not-production

# Mocked in tests, these values are irrelevant but some modules read them at import time
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tsts_test
DB_SYNC=false
DB_LOGGING=false
DB_RUN_MIGRATIONS=false

REDIS_HOST=localhost
REDIS_PORT=6379

MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_BUCKET=tsts-test
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=admin
MONGO_DB=tsts_test_mongo

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

CORS_ORIGINS=http://localhost
