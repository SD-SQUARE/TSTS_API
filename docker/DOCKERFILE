# -------- Optimized Build Stage --------
FROM node:20-alpine AS builder
WORKDIR /app

# Puppeteer is configured to use the system Chromium in production,
# so skip browser downloads during dependency installation.
ENV PUPPETEER_SKIP_DOWNLOAD=true

COPY package*.json ./
RUN npm ci --no-audit --no-fund \
    && npm cache clean --force

COPY . .
RUN npm run build

# -------- Optimized Production Stage --------
FROM node:20-alpine AS production
WORKDIR /app

# Install runtime packages only once in the final image.
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    && npm install -g pm2

ENV PUPPETEER_SKIP_DOWNLOAD=true \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

COPY package*.json ./
RUN npm ci --omit=dev --no-audit --no-fund \
    && npm cache clean --force

COPY --from=builder --chown=node:node /app/dist ./dist
COPY --from=builder --chown=node:node /app/src/locales ./dist/locales
COPY --from=builder --chown=node:node /app/assets ./assets

RUN mkdir -p /app/logs \
    && touch /app/ormlogs.log \
    && chown node:node /app/logs /app/ormlogs.log

USER node

EXPOSE 5050
EXPOSE 5000

CMD ["pm2-runtime", "dist/index.js"]

