# App
PROTOCOL=http
HOST=localhost
PORT=5000
NODE_ENV=development
# NODE_ENV=production
# NODE_ENV=test
TEST_MODE=true

# Cors
CORS_ORIGIN=http://localhost:3000

# Secrets
JWT_SECRET=example-secret
JWT_REFRESH_TOKEN_EXPIRATION=15d
JWT_ACCESS_TOKEN_EXPIRATION=1d

# Database
# @AhmedElsenaty
# TODO: Change default credientials in production
# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=tsts_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Minio
MINIO_PROTOCOL=http
MINIO_HOST=localhost
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_REGION=us-east-1
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin123
MINIO_BUCKET=tsts

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=example
MAIL_PASS=example