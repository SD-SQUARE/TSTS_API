{
  "name": "api",
  "version": "1.0.0",
  "description": "this is tsts project api",
  "keywords": [],
  "homepage": "https://github.com/SD-SQUARE/TSTS_API#readme",
  "bugs": {
    "url": "https://github.com/SD-SQUARE/TSTS_API/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SD-SQUARE/TSTS_API.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.ts",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc && npm run build:assets",
    "build:assets": "node scripts/copy-seed-assets.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "run-s db:start dev",
    "typeorm": "node ./scripts/typeorm.mjs",
    "db:start": "docker compose -f ./docker/compose.db.yml up --build -d",
    "db:stop": "docker compose -f ./docker/compose.db.yml down",
    "db:destroy": "docker compose -f ./docker/compose.db.yml down -v",
    "db:reset": "run-s db:destroy db:start dev",
    "migration:create": "npm run typeorm -- create",
    "migration:generate": "npm run typeorm -- generate",
    "migration:run": "tsx src/database/scripts/run-postgres-migrations.ts",
    "migration:show": "tsx src/database/scripts/show-postgres-migrations.ts",
    "migration:revert": "tsx src/database/scripts/revert-postgres-migration.ts",
    "migration:run:prod": "node dist/database/scripts/run-postgres-migrations.js",
    "migration:show:prod": "node dist/database/scripts/show-postgres-migrations.js",
    "migration:revert:prod": "node dist/database/scripts/revert-postgres-migration.js",
    "mongo:migration:run": "tsx src/database/mongo-migrations/index.ts run",
    "mongo:migration:show": "tsx src/database/mongo-migrations/index.ts show",
    "mongo:migration:run:prod": "node dist/database/mongo-migrations/index.js run",
    "mongo:migration:show:prod": "node dist/database/mongo-migrations/index.js show",
    "schema:apply": "run-s migration:run mongo:migration:run",
    "schema:apply:prod": "run-s migration:run:prod mongo:migration:run:prod",
    "seed": "tsx src/database/seeding/index.ts",
    "seed:system": "node dist/database/seeding/system.seeding.js",
    "seed:local": "tsx src/database/seeding/seed-local.ts",
    "seed:sys-data": "tsx src/database/seeding/sys-data.seed.ts",
    "seed-reports": "tsx src/database/seeding/reports/reports.seed.ts",
    "sp:seed": "tsx src/database/stored-procedures/seed-sp.ts",
    "seed:prod": "node dist/database/seeding/index.js",
    "seed:sys-data:prod": "node dist/database/seeding/sys-data.seed.js",
    "seed-reports:prod": "node dist/database/seeding/reports/reports.seed.js",
    "sp:seed:prod": "node dist/database/stored-procedures/seed-sp.js",
    "test": "jest --runInBand",
    "db:ProdBuild": "docker compose -f ./docker/compose.db.yml up --build -d",
    "db:ProdDown": "docker compose -f ./docker/compose.db.yml down",
    "api:ProdBuild": "docker compose -f ./docker/compose.api.yml up --build -d",
    "api:ProdDown": "docker compose -f ./docker/compose.api.yml down",
    "prod:build:start": "docker compose -f ./docker/compose.prod.yml up --build -d",
    "prod:start": "docker compose -f ./docker/compose.prod.yml up  -d",
    "prod:stop": "docker compose -f ./docker/compose.prod.yml down",
    "prod:host": "run-s secret:publish:staging prod:build:start",
    "ai:start": "docker compose -f ./docker/compose.ai.yml up -d",
    "ai:stop": "docker compose -f ./docker/compose.ai.yml down",
    "ai:pull": "docker exec ollama ollama pull llama3.2",
    "ai:logs": "docker logs ollama-pull --follow",
    "prod:with-ai:start": "docker compose -f ./docker/compose.prod.yml -f ./docker/compose.ai.yml up -d",
    "prod:with-ai:build": "docker compose -f ./docker/compose.prod.yml -f ./docker/compose.ai.yml up --build -d",
    "prod:with-ai:stop": "docker compose -f ./docker/compose.prod.yml -f ./docker/compose.ai.yml down",
    "secret:publish:staging": "npx tsx ./scripts/publish-env.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.936.0",
    "@aws-sdk/node-http-handler": "^3.370.0",
    "@aws-sdk/s3-request-presigner": "^3.936.0",
    "@faker-js/faker": "^10.1.0",
    "@simplewebauthn/server": "^13.2.2",
    "@types/multer": "^2.0.0",
    "archiver": "^7.0.1",
    "base64url": "^3.0.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "express-xss-sanitizer": "^2.0.1",
    "faker": "^6.6.6",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "i18next": "^25.6.3",
    "i18next-fs-backend": "^2.6.1",
    "i18next-http-middleware": "^3.8.2",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "mongodb": "^6.21.0",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "puppeteer": "^24.37.5",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.27",
    "winston": "^3.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^7.0.4",
    "@types/redis": "^4.0.10",
    "@types/socket.io": "^3.0.1",
    "@types/socket.io-client": "^1.4.36",
    "@types/supertest": "^6.0.3",
    "babel-jest": "^30.2.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "cpy-cli": "^6.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "npm-run-all": "^4.1.5",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
